---
// Page loader — pure CSS/HTML, renders before any JS hydration
---

<div id="cs-page-loader">
  <div id="cs-inner">
    <img
      src="/imagenes/Logo Gold.svg"
      alt="CourtSide Padel"
      id="cs-logo"
      width="160"
      height="72"
    />
    <p id="cs-tagline">Luxury Padel Retreats</p>
    <div id="cs-track">
      <div id="cs-bar"></div>
    </div>
  </div>
</div>

<style is:global>
  #cs-page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: cs-exit 0.6s cubic-bezier(0.22, 1, 0.36, 1) 1.7s both;
  }

  #cs-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    animation: cs-enter 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both;
  }

  #cs-logo {
    display: block;
    width: 148px;
    height: auto;
  }

  #cs-tagline {
    margin: 0;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.68rem;
    letter-spacing: 0.34em;
    color: #01192C;
    text-transform: uppercase;
    opacity: 0.5;
  }

  #cs-track {
    width: 64px;
    height: 1px;
    background: rgba(217, 173, 98, 0.18);
    overflow: hidden;
    border-radius: 9999px;
    margin-top: 0.1rem;
  }

  #cs-bar {
    height: 100%;
    width: 0%;
    background: #D9AD62;
    border-radius: 9999px;
    animation: cs-fill 1.3s cubic-bezier(0.4, 0, 0.2, 1) 0.3s both;
  }

  @keyframes cs-enter {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes cs-fill {
    from { width: 0%; }
    to   { width: 100%; }
  }

  @keyframes cs-exit {
    from { opacity: 1; }
    to   { opacity: 0; pointer-events: none; }
  }
</style>

<script>
  document.body.style.overflow = 'hidden';

  const loader = document.getElementById('cs-page-loader');
  if (loader) {
    loader.addEventListener('animationend', (e) => {
      if ((e as AnimationEvent).animationName === 'cs-exit') {
        document.body.style.overflow = '';
        loader.remove();
      }
    });
  }
</script>
