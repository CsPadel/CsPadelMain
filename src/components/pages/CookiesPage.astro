---
import Layout from '../../layouts/Layout.astro';
import CookiePolicyView from '../CookiePolicyView';
import FooterIsland from '../FooterIsland';
import type { Locale } from '../../i18n/locales';
import { getPageSeo, getAlternateUrls } from '../../i18n/seo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const seo = getPageSeo('cookies', locale);
const siteURL = Astro.site ?? new URL('https://courtsidepadel.com');
const alternateUrls = getAlternateUrls(siteURL.href, 'cookies');
---

<Layout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  lang={locale}
  locale={locale}
  canonical={alternateUrls[locale]}
  alternateUrls={alternateUrls}
>
  <main class="w-full min-h-screen bg-brand-dark flex flex-col relative overflow-x-hidden pt-24">
    <CookiePolicyView client:load locale={locale} />
    <FooterIsland client:load locale={locale} />
  </main>
</Layout>
