---
import Layout from '../../layouts/Layout.astro';
import DestinationLanding from '../DestinationLanding';
import type { Locale } from '../../i18n/locales';

interface Props {
  locale: Locale;
  destination: 'bali' | 'dubai';
}

const { locale, destination } = Astro.props;

const meta: Record<'bali' | 'dubai', Record<Locale, { title: string; description: string; keywords: string }>> = {
  bali: {
    en: {
      title: 'CourtSide | Bali Padel Retreat',
      description: 'Five days of elite padel, Balinese wellness and five-star luxury in Canggu. Join the CourtSide Bali retreat — July 2026.',
      keywords: 'Bali padel retreat, luxury padel Bali, Canggu padel, CourtSide Bali, padel holiday Indonesia',
    },
    es: {
      title: 'CourtSide | Retiro de Pádel en Bali',
      description: 'Cinco días de pádel de élite, bienestar balinés y lujo cinco estrellas en Canggu. Únete al retiro CourtSide Bali — Julio 2026.',
      keywords: 'retiro pádel Bali, pádel lujo Bali, Canggu pádel, CourtSide Bali',
    },
    fr: {
      title: 'CourtSide | Retraite Padel à Bali',
      description: 'Cinq jours de padel d\'élite, bien-être balinais et luxe cinq étoiles à Canggu. Rejoignez la retraite CourtSide Bali — Juillet 2026.',
      keywords: 'retraite padel Bali, padel luxe Bali, Canggu padel, CourtSide Bali',
    },
  },
  dubai: {
    en: {
      title: 'CourtSide | Dubai Padel Retreat',
      description: 'Four days of world-class padel, penthouse suites and elite networking in Dubai. The CourtSide Dubai retreat — November 2026.',
      keywords: 'Dubai padel retreat, luxury padel Dubai, CourtSide Dubai, padel UAE, executive padel retreat',
    },
    es: {
      title: 'CourtSide | Retiro de Pádel en Dubái',
      description: 'Cuatro días de pádel de primer nivel, suites ático y networking de élite en Dubái. El retiro CourtSide Dubái — Noviembre 2026.',
      keywords: 'retiro pádel Dubái, pádel lujo Dubái, CourtSide Dubái',
    },
    fr: {
      title: 'CourtSide | Retraite Padel à Dubaï',
      description: 'Quatre jours de padel de premier plan, suites penthouse et réseautage d\'élite à Dubaï. La retraite CourtSide Dubaï — Novembre 2026.',
      keywords: 'retraite padel Dubaï, padel luxe Dubaï, CourtSide Dubaï',
    },
  },
};

const seo = meta[destination][locale];
const siteURL = Astro.site ?? new URL('https://courtsidepadel.com');
const base = siteURL.href.replace(/\/$/, '');
const path = `/${destination}`;

const alternateUrls = {
  en: `${base}${path}`,
  es: `${base}/es${path}`,
  fr: `${base}/fr${path}`,
};
---

<Layout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  lang={locale}
  locale={locale}
  canonical={alternateUrls[locale]}
  alternateUrls={alternateUrls}
>
  <main class="w-full bg-white flex flex-col relative">
    <DestinationLanding client:load destination={destination} locale={locale} />
  </main>
</Layout>
