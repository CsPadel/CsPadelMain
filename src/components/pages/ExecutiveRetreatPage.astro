---
import Layout from '../../layouts/Layout.astro';
import FooterIsland from '../FooterIsland';
import type { Locale } from '../../i18n/locales';
import { getAlternateUrls } from '../../i18n/seo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const siteURL = Astro.site ?? new URL('https://courtsidepadel.com');
const alternateUrls = getAlternateUrls(siteURL.href, 'executiveRetreat');
---

<Layout
  title="Executive Retreat — CourtSide Padel"
  description="Strategy in silence. C-Suite and board-level padel retreats designed for absolute focus, elite networking and leadership development in Menorca."
  lang={locale}
  locale={locale}
  canonical={alternateUrls[locale]}
  alternateUrls={alternateUrls}
>
  <main class="w-full bg-white flex flex-col relative">

    {/* ── Hero ── */}
    <section class="relative w-full min-h-screen flex items-end pb-24 md:pb-32 px-8 md:px-16 overflow-hidden">
      <img
        src="/imagenes/EM-22.jpg"
        alt="Executive Retreat — CourtSide Padel"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
        decoding="async"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(1,25,44,0.25) 0%, rgba(1,25,44,0.55) 50%, rgba(1,25,44,0.97) 100%);"
      />
      <div class="relative z-10 max-w-7xl mx-auto w-full">
        <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold mb-5">
          C-Suite & Boards
        </p>
        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-light text-white leading-none mb-6"
          style="font-family: var(--font-display); font-style: italic;"
        >
          Strategy<br/>in silence.
        </h1>
        <p class="text-white/55 text-lg md:text-xl font-light max-w-xl leading-relaxed mb-10">
          The most exclusive setting for leadership teams, boards and C-suite networks. Where focus, performance and discretion converge.
        </p>
        <a
          href="mailto:executive@courtsidepadel.com"
          class="btn-luxury inline-flex items-center gap-3"
        >
          Request the Executive Dossier
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </section>

    {/* ── What it is ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-white">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
            <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
              The Format
            </p>
          </div>
          <h2
            class="text-4xl md:text-5xl font-light text-brand-dark leading-tight mb-8"
            style="font-family: var(--font-display); font-style: italic;"
          >
            A closed retreat.<br/>Your agenda.
          </h2>
          <p class="text-brand-dark/55 text-lg font-light leading-relaxed mb-6">
            The Executive Retreat is a fully closed, bespoke experience for leadership teams and boards. Your group has exclusive access to the entire property, courts, and concierge team for the duration of the retreat.
          </p>
          <p class="text-brand-dark/55 text-lg font-light leading-relaxed">
            We build the programme around your objectives — whether that's team cohesion, executive performance, client hospitality, or complete decompression. Padel is the vehicle. Clarity is the outcome.
          </p>
        </div>
        <div class="relative rounded-card overflow-hidden aspect-[4/3]">
          <img
            src="/imagenes/cap roig.jpg"
            alt="Executive Retreat setting"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    {/* ── Three pillars ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-brand-ivory">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <div class="flex items-center justify-center gap-4 mb-4">
            <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
            <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
              What You Get
            </p>
            <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
          </div>
          <h2
            class="text-4xl md:text-5xl font-light text-brand-dark"
            style="font-family: var(--font-display); font-style: italic;"
          >
            Designed for clarity.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
          {[
            {
              number: '01',
              title: 'Full Exclusivity',
              desc: 'Your team has the entire estate — courts, dining areas, accommodation and staff. Zero overlap with external guests.',
            },
            {
              number: '02',
              title: 'Bespoke Programme',
              desc: 'From coaching intensity to boardroom sessions, spa days and private dining — every element is built around your brief.',
            },
            {
              number: '03',
              title: 'Total Discretion',
              desc: 'NDAs, private arrival logistics, and our commitment to absolute confidentiality for board-level and investor retreats.',
            },
          ].map((pillar) => (
            <div class="group">
              <p class="text-[10px] uppercase tracking-[0.3em] text-brand-gold font-semibold mb-4">{pillar.number}</p>
              <h3
                class="text-xl md:text-2xl font-light text-brand-dark mb-4 leading-snug"
                style="font-family: var(--font-display); font-style: italic;"
              >
                {pillar.title}
              </h3>
              <div class="h-px w-8 bg-brand-gold/30 mb-4" />
              <p class="text-brand-dark/55 font-light leading-relaxed">{pillar.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Three categories ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-brand-dark">
      <div class="max-w-7xl mx-auto">
        <div class="mb-14">
          <div class="flex items-center gap-4 mb-5">
            <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
            <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
              Retreat Objectives
            </p>
          </div>
          <h2
            class="text-4xl md:text-5xl font-light text-white leading-none"
            style="font-family: var(--font-display); font-style: italic;"
          >
            Tailored to your intent.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {[
            {
              image: '/imagenes/JOPS-1071.JPG',
              tag: 'Leadership Development',
              title: 'Sharpen minds. Elevate performance.',
              desc: 'Strategic coaching sessions designed to forge decisive leaders under pressure — on court and in the boardroom.',
            },
            {
              image: '/imagenes/2808 copy.jpg',
              tag: 'Team Building',
              title: 'Build trust. Play together. Win together.',
              desc: 'Curated group experiences that strengthen cohesion, communication and collective drive across your team.',
            },
            {
              image: '/imagenes/cap roig.jpg',
              tag: 'C-Suite Retreat',
              title: 'Silence the noise. Think clearly.',
              desc: 'Exclusive access for boards and executive committees. High-calibre networking in the most private settings.',
            },
          ].map((cat) => (
            <div
              class="group relative overflow-hidden rounded-card"
              style="min-height: 420px;"
            >
              <img
                src={cat.image}
                alt={cat.tag}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div
                class="absolute inset-0"
                style="background: linear-gradient(to bottom, rgba(1,25,44,0.15) 0%, rgba(1,25,44,0.60) 45%, rgba(1,25,44,0.97) 100%);"
              />
              <div class="absolute bottom-0 left-0 right-0 p-7 md:p-8">
                <span class="text-[9px] uppercase tracking-[0.28em] text-brand-gold font-semibold mb-3 block">
                  {cat.tag}
                </span>
                <h3
                  class="text-xl md:text-2xl font-light text-white mb-3 leading-snug"
                  style="font-family: var(--font-display); font-style: italic;"
                >
                  {cat.title}
                </h3>
                <p class="text-white/55 text-sm font-light leading-relaxed">{cat.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── CTA ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-white">
      <div class="max-w-3xl mx-auto text-center">
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
          <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
            Start the Conversation
          </p>
          <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
        </div>
        <h2
          class="text-4xl md:text-5xl font-light text-brand-dark mb-6"
          style="font-family: var(--font-display); font-style: italic;"
        >
          Every executive retreat<br/>begins with a brief.
        </h2>
        <p class="text-brand-dark/50 text-lg font-light leading-relaxed mb-10 max-w-xl mx-auto">
          Tell us your objectives, group size and preferred dates. We'll build the programme around you.
        </p>
        <a
          href="mailto:executive@courtsidepadel.com"
          class="btn-luxury inline-flex items-center gap-3"
        >
          Request the Executive Dossier
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <p class="text-brand-dark/30 text-xs mt-5 tracking-wide">Handled in complete confidence · No obligation</p>
      </div>
    </section>

    <FooterIsland client:visible locale={locale} />
  </main>
</Layout>
