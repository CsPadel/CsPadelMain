---
import Layout from '../../layouts/Layout.astro';
import { HeroRouter } from '../HeroRouter';
import RetreatTypesSection from '../RetreatTypesSection';
import BespokeRetreats from '../BespokeRetreats';
import TestimonialsCarousel from '../TestimonialsCarousel';
import PartnersSection from '../PartnersSection';
import FooterIsland from '../FooterIsland';
import type { Locale } from '../../i18n/locales';
import { getPageSeo, getAlternateUrls } from '../../i18n/seo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const seo = getPageSeo('home', locale);
const siteURL = Astro.site ?? new URL('https://courtsidepadel.com');
const alternateUrls = getAlternateUrls(siteURL.href, 'home');
---

<Layout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  lang={locale}
  locale={locale}
  canonical={alternateUrls[locale]}
  alternateUrls={alternateUrls}
>
  <main class="w-full bg-white flex flex-col relative">
    <HeroRouter client:load locale={locale} />
    <RetreatTypesSection client:visible locale={locale} />
    <BespokeRetreats client:visible />
    <TestimonialsCarousel client:visible />
    <PartnersSection client:load />
    <FooterIsland client:visible locale={locale} />
  </main>
</Layout>
