---
import Layout from '../../layouts/Layout.astro';
import FooterIsland from '../FooterIsland';
import FoundersSection from '../FoundersSection';
import type { Locale } from '../../i18n/locales';
import { getAlternateUrls } from '../../i18n/seo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const siteURL = Astro.site ?? new URL('https://courtsidepadel.com');
const alternateUrls = getAlternateUrls(siteURL.href, 'ourStory');
---

<Layout
  title="Our Story — CourtSide Padel"
  description="Alex and Oli built CourtSide from a shared obsession with padel and a belief that a sports retreat could be genuinely extraordinary. This is their story."
  lang={locale}
  locale={locale}
  canonical={alternateUrls[locale]}
  alternateUrls={alternateUrls}
>
  <main class="w-full bg-white flex flex-col relative">

    {/* ── Hero ── */}
    <section class="relative w-full min-h-screen flex items-end pb-24 md:pb-32 px-8 md:px-16 overflow-hidden">
      <img
        src="/imagenes/EM-4.jpg"
        alt="CourtSide Padel — Our Story"
        class="absolute inset-0 w-full h-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(1,25,44,0.10) 0%, rgba(1,25,44,0.40) 45%, rgba(1,25,44,0.97) 100%);"
      />
      <div class="relative z-10 max-w-7xl mx-auto w-full">
        <div
          class="flex items-center gap-4 mb-6"
          style="animation: cs-enter 0.8s cubic-bezier(0.22,1,0.36,1) 0.3s both;"
        >
          <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
          <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
            The Founders
          </p>
        </div>
        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-light text-white leading-none mb-6"
          style="font-family: var(--font-display); font-style: italic; animation: cs-enter 0.9s cubic-bezier(0.22,1,0.36,1) 0.45s both;"
        >
          Our Story.
        </h1>
        <p
          class="text-white/55 text-lg md:text-xl font-light max-w-md leading-relaxed"
          style="animation: cs-enter 0.8s cubic-bezier(0.22,1,0.36,1) 0.65s both;"
        >
          Two friends. One obsession. And a belief that a padel retreat could be something truly extraordinary.
        </p>
      </div>
    </section>

    {/* ── Origin story ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-white overflow-hidden">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-start">

        <div class="md:sticky md:top-32 cs-fadein">
          <div class="flex items-center gap-4 mb-6">
            <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
            <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
              How It Began
            </p>
          </div>
          <h2
            class="text-4xl md:text-5xl font-light text-brand-dark leading-tight"
            style="font-family: var(--font-display); font-style: italic;"
          >
            Born from a<br/>shared obsession.
          </h2>
        </div>

        <div class="space-y-7 text-brand-dark/58 text-base md:text-lg font-light leading-relaxed cs-fadein" style="animation-delay: 0.15s;">
          <p>
            Alex and Oli met through padel. What started as a shared love of the sport became a shared frustration: there was no retreat that combined serious padel with the standard of experience they expected in everything else they did.
          </p>
          <p>
            The luxury retreats felt generic. The padel-specific trips felt amateur. Neither had the soul, the curation, or the attention to detail that makes something truly unforgettable.
          </p>
          <p>
            So they built it themselves — in Menorca, an island they both loved, designed around a single question: <em class="text-brand-dark/80 not-italic">"Would we want this?"</em>
          </p>
        </div>
      </div>
    </section>

    {/* ── Founders header ── */}
    <div class="bg-brand-ivory px-8 md:px-16 pt-20 md:pt-28 pb-0 cs-fadein">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
          <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
            The People Behind It
          </p>
        </div>
        <h2
          class="text-3xl md:text-4xl font-light text-brand-dark"
          style="font-family: var(--font-display); font-style: italic;"
        >
          Meet the founders.
        </h2>
      </div>
    </div>

    {/* ── Founders (animated React island) ── */}
    <FoundersSection client:visible />

    {/* ── Philosophy quote ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-brand-dark">
      <div class="max-w-4xl mx-auto text-center cs-fadein">
        <div class="flex items-center justify-center gap-4 mb-10">
          <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
          <p class="text-[9px] uppercase tracking-[0.38em] text-brand-gold font-semibold">
            What We Believe
          </p>
          <span class="block h-px w-7 bg-brand-gold/40" aria-hidden="true" />
        </div>
        <blockquote
          class="text-3xl md:text-4xl lg:text-5xl font-light text-white leading-tight mb-10"
          style="font-family: var(--font-display); font-style: italic;"
        >
          "Padel is the excuse.<br/>The experience is the reason."
        </blockquote>
        <p class="text-white/40 text-base font-light leading-relaxed max-w-xl mx-auto">
          The best retreats don't feel like events. They feel like the week you keep talking about three years later.
        </p>
      </div>
    </section>

    {/* ── CTA ── */}
    <section class="py-24 md:py-32 px-8 md:px-16 bg-white">
      <div class="max-w-3xl mx-auto text-center cs-fadein">
        <h2
          class="text-4xl md:text-5xl font-light text-brand-dark mb-5"
          style="font-family: var(--font-display); font-style: italic;"
        >
          Ready to experience it?
        </h2>
        <p class="text-brand-dark/45 text-base font-light leading-relaxed mb-10 max-w-sm mx-auto">
          The next Menorca retreat is filling fast.
        </p>
        <a
          href="/menorca"
          class="btn-luxury inline-flex items-center gap-3"
        >
          View the Menorca Retreat
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>

    <FooterIsland client:visible locale={locale} />
  </main>
</Layout>

<style is:global>
  /* Scroll-triggered fade-in for static Astro sections */
  .cs-fadein {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cs-fadein.cs-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('cs-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '-40px' }
  );

  document.querySelectorAll('.cs-fadein').forEach((el) => observer.observe(el));
</script>
