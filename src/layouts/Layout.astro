---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import CookieConsent from '../components/CookieConsent';
import WhatsAppConciergeButton from '../components/WhatsAppConciergeButton';
import PageLoader from '../components/PageLoader.astro';
import type { Locale } from '../i18n/locales';
import { ogLocales } from '../i18n/locales';
import { GA_ADS_ID } from '../lib/gtag';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	ogType?: string;
	canonical?: string;
	schema?: object;
	lang?: string;
	locale?: Locale;
	alternateUrls?: Partial<Record<Locale, string>>;
}

const {
	title,
	description = "Premium Padel Retreats in the Mediterranean. Book a private suite or exclusive villa. CourtSide — where world-class padel meets ultra-luxury.",
	keywords = "padel retreat, luxury padel holiday, Menorca padel, padel experience, private padel villa, CourtSide padel",
	ogImage = "/imagenes/EM-2.jpg",
	ogType = "website",
	canonical,
	schema,
	lang = "en",
	locale = "en",
	alternateUrls = {}
} = Astro.props;

const siteURL = Astro.site ?? new URL("https://courtsidepadel.com");
const canonicalURL = canonical ?? Astro.url.href;

const ogImageAbsolute = ogImage.startsWith("http")
	? ogImage
	: new URL(ogImage, siteURL).href;

const hreflangEntries = Object.entries(alternateUrls).filter(
	([, href]) => Boolean(href)
) as Array<[Locale, string]>;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalURL} />

		{hreflangEntries.map(([hrefLang, href]) => (
			<link rel="alternate" hreflang={hrefLang} href={href} />
		))}
		{alternateUrls.en && (
			<link rel="alternate" hreflang="x-default" href={alternateUrls.en} />
		)}

		<link rel="sitemap" type="application/xml" href="/sitemap.xml" />

		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageAbsolute} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />
		<meta property="og:site_name" content="CourtSide Padel Retreats" />
		<meta property="og:locale" content={ogLocales[locale]} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@courtsidepadel" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageAbsolute} />
		<meta name="twitter:image:alt" content={title} />

		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="theme-color" content="#01192C" />

		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- Non-blocking font load — media trick loads stylesheet async, then swaps to all -->
		<link
		  rel="stylesheet"
		  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap"
		  media="print"
		  onload="this.media='all'"
		/>
		<noscript>
		  <link
		    rel="stylesheet"
		    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap"
		  />
		</noscript>

		{/* ── Google Ads global site tag ── */}
		{/* Replace AW-XXXXXXXXXX in src/lib/gtag.ts with your real Google Ads Conversion ID */}
		<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ADS_ID}`}></script>
		<script is:inline define:vars={{ gaAdsId: GA_ADS_ID }}>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', gaAdsId);
		</script>

		{schema && (
			<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
		)}
	</head>
	<body
		class="bg-white text-brand-dark font-inter antialiased selection:bg-brand-gold selection:text-brand-dark"
		style="font-feature-settings: 'kern' 1, 'liga' 1;"
		data-locale={locale}
	>
		<PageLoader />
		<Navbar client:load locale={locale} />
		<div id="page-content">
			<slot />
		</div>
		<CookieConsent client:load locale={locale} />
		<WhatsAppConciergeButton client:load locale={locale} />
	</body>
</html>
