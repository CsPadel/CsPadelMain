---
import Layout from '../layouts/Layout.astro';
import RetreatLandingHero from '../components/RetreatLandingHero';
import RoomsSelector from '../components/RoomsSelector';
import MenorcaItinerary from '../components/MenorcaItinerary';
import MenorcaWhatsIncluded from '../components/MenorcaWhatsIncluded';
import BespokeRetreats from '../components/BespokeRetreats';
import TestimonialsCarousel from '../components/TestimonialsCarousel';
import FooterIsland from '../components/FooterIsland';
import FAQ from '../components/FAQ';

const SITE = "https://courtsidepadel.com";
const seoTitle = "Menorca Padel Retreat 2026 | Luxury Padel Holiday Mediterranean | CourtSide";
const seoDescription = "Experience the ultimate luxury padel retreat in Menorca. 5 days of private coaching, boat tours, vineyard visits, padel tournament & gourmet dining. 30 Sep – 4 Oct 2026.";
const seoKeywords = "Menorca padel retreat, luxury padel holiday Menorca, padel training Mediterranean, private padel villa Spain, CourtSide Menorca, padel vacation 2026, padel coaching retreat, padel holiday Balearic Islands";

const menorcaSchema = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  "name": "CourtSide Menorca Padel Retreat 2026",
  "description": seoDescription,
  "url": `${SITE}/menorca`,
  "image": `${SITE}/imagenes/EM-2.jpg`,
  "touristType": ["Sports Enthusiast", "Luxury Traveler"],
  "duration": "P5D",
  "itinerary": {
    "@type": "ItemList",
    "numberOfItems": 5,
    "name": "5-Day Menorca Padel Retreat Itinerary",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Arrival & Welcome — Airport transfers, check-in, seaside lunch, warm-up padel session, welcome dinner" },
      { "@type": "ListItem", "position": 2, "name": "Padel & Boat Tour — Morning coaching at Padelin, lunch and boat tour from Sa Punta restaurant" },
      { "@type": "ListItem", "position": 3, "name": "Padel & Vineyard — Court sessions, vineyard tour and lunch at Binifadet winery" },
      { "@type": "ListItem", "position": 4, "name": "Tournament & Sunset — Mixed doubles round-robin tournament, awards lunch, sunset tapas at Cova d'en Xoroi" },
      { "@type": "ListItem", "position": 5, "name": "Final Session & Farewell — Final breakfast, optional padel session, private airport transfers" }
    ]
  },
  "provider": {
    "@type": "Organization",
    "name": "CourtSide Padel Retreats",
    "url": SITE,
    "logo": `${SITE}/logogold.webp`,
    "sameAs": []
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "Personal Suite — Menorca Padel Retreat",
      "description": "Private suite for individuals or couples. Includes coaching, wellness, and all retreat activities.",
      "price": "120",
      "priceCurrency": "GBP",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "120", "priceCurrency": "GBP", "unitText": "night" },
      "availability": "https://schema.org/LimitedAvailability",
      "validFrom": "2026-09-30",
      "validThrough": "2026-10-04",
      "url": `${SITE}/menorca#book`
    },
    {
      "@type": "Offer",
      "name": "Full Villa — Exclusive Menorca Padel Retreat",
      "description": "Entire villa exclusively for groups of 8–20 guests. Complete privacy with private chef and dedicated concierge team.",
      "price": "200",
      "priceCurrency": "GBP",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "200", "priceCurrency": "GBP", "unitText": "night" },
      "availability": "https://schema.org/LimitedAvailability",
      "url": `${SITE}/menorca#book`
    },
    {
      "@type": "Offer",
      "name": "Executive Retreat — C-Suite Menorca Padel Programme",
      "description": "C-suite padel retreat with private meeting rooms, strategy sessions, and absolute discretion.",
      "price": "100",
      "priceCurrency": "GBP",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "100", "priceCurrency": "GBP", "unitText": "night" },
      "availability": "https://schema.org/LimitedAvailability",
      "url": `${SITE}/menorca#book`
    }
  ],
  "location": {
    "@type": "Place",
    "name": "Menorca, Balearic Islands, Spain",
    "geo": { "@type": "GeoCoordinates", "latitude": "39.9496", "longitude": "4.1183" },
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Menorca",
      "addressCountry": "ES",
      "addressLocality": "Balearic Islands"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "bestRating": "5",
    "worstRating": "1",
    "reviewCount": "2"
  },
  "review": [
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Tomasz Campbell" },
      "reviewBody": "Truly life-changing. The coaching sessions elevated my game, but the yacht day and gourmet dinners made it a complete luxury escape. Already booked for next year."
    },
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Ana Martínez" },
      "reviewBody": "The attention to detail is unreal. From the airport transfer to the farewell dinner, every moment felt tailored. This is how a padel retreat should be."
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need padel experience?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Our retreats welcome all levels — coaching is tailored from beginners building foundations to advanced players refining strategy."
      }
    },
    {
      "@type": "Question",
      "name": "Is everything included?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Everything in the itinerary is included — accommodation, all meals, coaching, matchplay, local transport, and activities. Guests are welcome to skip any activity. Anything booked outside the itinerary is at the guest's own cost."
      }
    },
    {
      "@type": "Question",
      "name": "Are flights and airport transfers included?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Transfers to and from Mahón Airport are included. Flights are not — our concierge can advise on routes or arrange a private charter on request."
      }
    },
    {
      "@type": "Question",
      "name": "Can a non-playing partner come along?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Non-playing partners pay the same retreat price, and their programme can be customised around their preferences."
      }
    },
    {
      "@type": "Question",
      "name": "What about dietary requirements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our on-site private chef builds bespoke menus around a wellness and dietary questionnaire sent before arrival."
      }
    },
    {
      "@type": "Question",
      "name": "How many guests per retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Each open retreat is capped to preserve exclusivity. Private retreats run for a minimum of 6 guests."
      }
    },
    {
      "@type": "Question",
      "name": "Can I extend my stay before or after the retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — we can arrange additional nights at Barceló Nura on request."
      }
    },
    {
      "@type": "Question",
      "name": "Can I book a private retreat on different dates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We run fully bespoke private retreats on any week of the year, with a minimum of 6 guests and 2 months' lead time."
      }
    },
    {
      "@type": "Question",
      "name": "When is the next Menorca retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "30 September – 4 October 2026 (4 nights, 5 days). Places are limited — early booking is advised."
      }
    },
    {
      "@type": "Question",
      "name": "What's the deposit and when is the balance due?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 40% deposit secures your place. The remaining balance is due 6 weeks before the retreat start date."
      }
    },
    {
      "@type": "Question",
      "name": "What's the cancellation policy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cancellations made more than 10 weeks before the retreat start date are eligible for a full deposit refund. Within 10 weeks of the start date, the 40% deposit becomes non-refundable."
      }
    }
  ]
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CourtSide Padel Retreats",
  "url": SITE,
  "logo": `${SITE}/logogold.webp`,
  "description": "Ultra-luxury padel retreats in the world's most exclusive destinations. CourtSide combines world-class padel coaching with five-star hospitality.",
  "foundingDate": "2024",
  "areaServed": ["Menorca", "Bali", "Dubai"],
  "serviceType": "Luxury Padel Retreat",
  "sameAs": []
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogImage="/imagenes/EM-2.jpg"
  canonical="https://courtsidepadel.com/menorca"
  schema={menorcaSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />

  <main class="w-full min-h-screen bg-brand-dark flex flex-col relative overflow-x-hidden pt-24">

    <!-- ========== HERO ========== -->
    <RetreatLandingHero destination="menorca" bgVideoSrc="/vid2.mp4" client:load />

    <!-- ========== WHAT'S INCLUDED ========== -->
    <MenorcaWhatsIncluded client:load />

    <!-- ========== DISCOVER OUR ROOMS ========== -->
    <RoomsSelector client:load />

    <!-- ========== THE ITINERARY ========== -->
    <MenorcaItinerary client:load />

    <!-- ========== BESPOKE RETREATS ========== -->
    <BespokeRetreats client:load />

    <!-- ========== TESTIMONIALS ========== -->
    <TestimonialsCarousel client:load />

    <!-- ========== FAQ ========== -->
    <FAQ destination="menorca" theme="light" client:load />

    <!-- ========== BOOK NOW CTA ========== -->
    <section id="book" aria-label="Book your CourtSide Menorca padel retreat" class="relative py-28 md:py-40 px-6 md:px-16 overflow-hidden">
      <img
        src="/imagenes/IMG_2914.JPG"
        alt="Book your luxury Menorca padel retreat with CourtSide — limited places 2026"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        width="1200"
        height="700"
      />
      <div class="absolute inset-0 bg-brand-dark/75 bg-gradient-to-t from-brand-dark via-brand-dark/60 to-brand-dark/40"></div>

      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Limited places each season</p>
        <h2 class="text-5xl md:text-7xl font-light text-brand-light mb-6 tracking-wide">Book Now</h2>
        <p class="text-brand-light/70 text-xl mb-12 max-w-lg mx-auto">
          Secure your place at the most exclusive padel retreat in the Mediterranean.
        </p>

        <!-- Quick booking summary -->
        <div class="flex flex-col md:flex-row justify-center gap-0 mb-10 border border-white/20 max-w-2xl mx-auto">
          <div class="flex-1 px-6 py-5 border-b md:border-b-0 md:border-r border-white/20 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Destination</p>
            <p class="text-brand-light font-semibold text-lg">Menorca</p>
          </div>
          <div class="flex-1 px-6 py-5 border-b md:border-b-0 md:border-r border-white/20 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Available Dates</p>
            <p class="text-brand-light font-semibold text-lg">30 Sep – 4 Oct 2026</p>
          </div>
          <div class="flex-1 px-6 py-5 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Accommodation</p>
            <p class="text-brand-light font-semibold text-lg">Suite · Villa · Executive</p>
          </div>
        </div>

        <a
          href="#"
          onclick="document.querySelector('[data-book-btn]')?.click(); return false;"
          class="inline-flex items-center gap-3 px-12 py-5 bg-brand-gold text-brand-dark font-bold uppercase tracking-widest text-sm hover:bg-brand-light transition-colors duration-300"
          aria-label="Secure your place at CourtSide Menorca padel retreat 2026"
        >
          Secure Your Place →
        </a>

        <p class="text-brand-light/30 text-sm mt-6">No commitment required. Speak with your Personal Concierge first.</p>
      </div>
    </section>

    <FooterIsland client:load />
  </main>
</Layout>
