---
import Layout from '../layouts/Layout.astro';
import RetreatLandingHero from '../components/RetreatLandingHero';
import RoomsSelector from '../components/RoomsSelector';
import MenorcaItinerary from '../components/MenorcaItinerary';
import LicenceToLive from '../components/LicenceToLive';
import TestimonialsCarousel from '../components/TestimonialsCarousel';
import FooterIsland from '../components/FooterIsland';

const SITE = "https://courtsidepadel.com";
const seoTitle = "Menorca Padel Retreat 2026 | Luxury Padel Holiday Mediterranean | CourtSide";
const seoDescription = "Experience the ultimate luxury padel retreat in Menorca. 5 days of private coaching, boat tours, vineyard visits, padel tournament & gourmet dining. 30 Sep – 4 Oct 2026.";
const seoKeywords = "Menorca padel retreat, luxury padel holiday Menorca, padel training Mediterranean, private padel villa Spain, CourtSide Menorca, padel vacation 2026, padel coaching retreat, padel holiday Balearic Islands";

const menorcaSchema = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  "name": "CourtSide Menorca Padel Retreat 2026",
  "description": seoDescription,
  "url": `${SITE}/menorca`,
  "image": `${SITE}/imagenes/EM-2.jpg`,
  "touristType": ["Sports Enthusiast", "Luxury Traveler"],
  "duration": "P5D",
  "itinerary": {
    "@type": "ItemList",
    "numberOfItems": 5,
    "name": "5-Day Menorca Padel Retreat Itinerary",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Arrival & Warm-Up — Airport transfers, hotel check-in, light padel session, welcome dinner at Ses Forquilles" },
      { "@type": "ListItem", "position": 2, "name": "Padel & Boat Tour — Morning coaching at Padelin, lunch and boat tour from Sa Punta restaurant" },
      { "@type": "ListItem", "position": 3, "name": "Padel & Vineyard — Court sessions, vineyard tour and lunch at Binifadet winery" },
      { "@type": "ListItem", "position": 4, "name": "Tournament & Sunset — Mixed doubles round-robin tournament, awards lunch, sunset tapas at Cova d'en Xoroi" },
      { "@type": "ListItem", "position": 5, "name": "Departure — Final breakfast, optional padel session, private airport transfers" }
    ]
  },
  "provider": {
    "@type": "Organization",
    "name": "CourtSide Padel Retreats",
    "url": SITE,
    "logo": `${SITE}/logogold.webp`,
    "sameAs": []
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "Personal Suite — Menorca Padel Retreat",
      "description": "Private suite for individuals or couples. Includes coaching, wellness, and all retreat activities.",
      "price": "120",
      "priceCurrency": "GBP",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "120", "priceCurrency": "GBP", "unitText": "night" },
      "availability": "https://schema.org/LimitedAvailability",
      "validFrom": "2026-09-30",
      "validThrough": "2026-10-04",
      "url": `${SITE}/menorca#book`
    },
    {
      "@type": "Offer",
      "name": "Full Villa — Exclusive Menorca Padel Retreat",
      "description": "Entire villa exclusively for groups of 8–20 guests. Complete privacy with private chef and dedicated concierge team.",
      "price": "200",
      "priceCurrency": "GBP",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "200", "priceCurrency": "GBP", "unitText": "night" },
      "availability": "https://schema.org/LimitedAvailability",
      "url": `${SITE}/menorca#book`
    },
    {
      "@type": "Offer",
      "name": "Executive Retreat — C-Suite Menorca Padel Programme",
      "description": "C-suite padel retreat with private meeting rooms, strategy sessions, and absolute discretion.",
      "price": "100",
      "priceCurrency": "GBP",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "100", "priceCurrency": "GBP", "unitText": "night" },
      "availability": "https://schema.org/LimitedAvailability",
      "url": `${SITE}/menorca#book`
    }
  ],
  "location": {
    "@type": "Place",
    "name": "Menorca, Balearic Islands, Spain",
    "geo": { "@type": "GeoCoordinates", "latitude": "39.9496", "longitude": "4.1183" },
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Menorca",
      "addressCountry": "ES",
      "addressLocality": "Balearic Islands"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "bestRating": "5",
    "worstRating": "1",
    "reviewCount": "2"
  },
  "review": [
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Tomasz Campbell" },
      "reviewBody": "Truly life-changing. The coaching sessions elevated my game, but the yacht day and gourmet dinners made it a complete luxury escape. Already booked for next year."
    },
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Ana Martínez" },
      "reviewBody": "The attention to detail is unreal. From the airport transfer to the farewell dinner, every moment felt tailored. This is how a padel retreat should be."
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What skill level is required for the Menorca padel retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our coaches tailor sessions to all levels, from beginners looking for foundation building to advanced players refining strategy."
      }
    },
    {
      "@type": "Question",
      "name": "Is the flight included in the Menorca padel retreat package?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Flights are not included in the standard package, however our private Concierge can arrange private charters or commercial flights upon request."
      }
    },
    {
      "@type": "Question",
      "name": "Are dietary requirements catered for at the Menorca retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our on-site private chef curates bespoke menus based on a detailed wellness questionnaire sent prior to your arrival."
      }
    },
    {
      "@type": "Question",
      "name": "How many guests are in each Menorca padel retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We cap each retreat to ensure exclusivity. Personal suites accommodate individuals and couples; Full Villa exclusivity is available for groups of 8–20 guests."
      }
    },
    {
      "@type": "Question",
      "name": "When are the 2026 Menorca padel retreat dates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Menorca Padel Retreat runs 30 September – 4 October 2026 (4 nights, 5 days). Limited places — early booking is strongly advised."
      }
    }
  ]

};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CourtSide Padel Retreats",
  "url": SITE,
  "logo": `${SITE}/logogold.webp`,
  "description": "Ultra-luxury padel retreats in the world's most exclusive destinations. CourtSide combines world-class padel coaching with five-star hospitality.",
  "foundingDate": "2024",
  "areaServed": ["Menorca", "Bali", "Dubai"],
  "serviceType": "Luxury Padel Retreat",
  "sameAs": []
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogImage="/imagenes/EM-2.jpg"
  canonical="https://courtsidepadel.com/menorca"
  schema={menorcaSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />

  <main class="w-full min-h-screen bg-brand-dark flex flex-col relative overflow-x-hidden pt-24">

    <!-- ========== HERO ========== -->
    <RetreatLandingHero destination="menorca" bgVideoSrc="/vid2.mp4" client:load />

    <!-- ========== WHAT'S INCLUDED ========== -->
    <section id="includes" aria-label="What is included in the Menorca padel retreat" class="bg-brand-dark py-24 md:py-32 px-6 md:px-16">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-light text-center text-brand-light mb-4 tracking-wide">
          What's included?
        </h2>
        <p class="text-brand-light/50 text-center text-lg mb-20 max-w-xl mx-auto">
          Every detail curated so you can focus on performance and recovery.
        </p>

        <div class="flex flex-col gap-20">
          <!-- Feature 1: Chef -->
          <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
            <div class="w-full md:w-1/2 order-2 md:order-1">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Private Chef</p>
              <h3 class="text-2xl md:text-3xl font-light text-brand-light mb-5 leading-snug">
                Bespoke menus crafted around your wellness.
              </h3>
              <p class="text-brand-light/60 text-lg leading-relaxed">
                Our on-site private chef curates bespoke menus based on a detailed wellness questionnaire sent prior to your arrival. Every meal is a performance fuel.
              </p>
            </div>
            <div class="w-full md:w-1/2 order-1 md:order-2 overflow-hidden">
              <img
                src="/imagenes/bambu.jpg"
                alt="Private chef preparing bespoke wellness meals at CourtSide Menorca retreat"
                class="w-full h-72 md:h-96 object-cover"
                loading="lazy"
                decoding="async"
                width="640"
                height="480"
              />
            </div>
          </div>

          <!-- Feature 2: Padel Coaching -->
          <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
            <div class="w-full md:w-1/2 overflow-hidden">
              <img
                src="/imagenes/JOPS-1071.JPG"
                alt="Professional padel coaching session at CourtSide Menorca luxury retreat"
                class="w-full h-72 md:h-96 object-cover"
                loading="lazy"
                decoding="async"
                width="640"
                height="480"
              />
            </div>
            <div class="w-full md:w-1/2">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Expert Coaching</p>
              <h3 class="text-2xl md:text-3xl font-light text-brand-light mb-5 leading-snug">
                Sessions tailored to your exact level.
              </h3>
              <p class="text-brand-light/60 text-lg leading-relaxed">
                Our coaches tailor sessions to all levels, from beginners looking for foundation building to advanced players refining strategy on the court.
              </p>
            </div>
          </div>

          <!-- Feature 3: Yacht -->
          <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
            <div class="w-full md:w-1/2 order-2 md:order-1">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Yacht Escapes</p>
              <h3 class="text-2xl md:text-3xl font-light text-brand-light mb-5 leading-snug">
                Private sailing to secluded Mediterranean coves.
              </h3>
              <p class="text-brand-light/60 text-lg leading-relaxed">
                Afternoon charter yacht excursions to Menorca's most untouched coastlines. Premium catering, ocean relaxation, and on-deck physiotherapy as the sun sets.
              </p>
            </div>
            <div class="w-full md:w-1/2 order-1 md:order-2 overflow-hidden">
              <img
                src="/imagenes/Cala en porter.jpg"
                alt="Charter yacht excursion to secluded coves in Menorca, included in CourtSide retreat"
                class="w-full h-72 md:h-96 object-cover"
                loading="lazy"
                decoding="async"
                width="640"
                height="480"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== DISCOVER OUR ROOMS ========== -->
    <RoomsSelector client:load />

    <!-- ========== THE ITINERARY ========== -->
    <MenorcaItinerary client:load />

    <!-- ========== LICENCE TO LIVE ========== -->
    <LicenceToLive client:load />

    <!-- ========== TESTIMONIALS ========== -->
    <TestimonialsCarousel client:load />

    <!-- ========== FAQ ========== -->
    <section id="faq" aria-label="Frequently asked questions about Menorca padel retreat" class="bg-gray-50 py-24 md:py-32 px-6 md:px-16">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-light text-center text-gray-900 mb-16 tracking-wide">
          Frequently Asked Questions
        </h2>

        <dl class="space-y-0 divide-y divide-gray-200">
          <div class="py-8">
            <dt class="text-xl font-light text-gray-900 mb-3">What skill level is required?</dt>
            <dd class="text-gray-600 leading-relaxed">Our coaches tailor sessions to all levels, from beginners looking for foundation building to advanced players refining strategy.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-gray-900 mb-3">Is the flight included?</dt>
            <dd class="text-gray-600 leading-relaxed">Flights are not included in the standard package, however our private Concierge can arrange private charters or commercial flights upon request.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-gray-900 mb-3">What about dietary requirements?</dt>
            <dd class="text-gray-600 leading-relaxed">Our on-site private chef curates bespoke menus based on a detailed wellness questionnaire sent prior to your arrival.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-gray-900 mb-3">How many guests per retreat?</dt>
            <dd class="text-gray-600 leading-relaxed">We cap each retreat to ensure exclusivity. Personal suites accommodate individuals and couples; Full Villa exclusivity is available for groups of 8–20 guests.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-gray-900 mb-3">When are the 2026 Menorca retreat dates?</dt>
            <dd class="text-gray-600 leading-relaxed">The retreat runs 30 September – 4 October 2026 (4 nights, 5 days). Limited places — early booking is strongly advised.</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ========== BOOK NOW CTA ========== -->
    <section id="book" aria-label="Book your CourtSide Menorca padel retreat" class="relative py-28 md:py-40 px-6 md:px-16 overflow-hidden">
      <img
        src="/imagenes/IMG_2914.JPG"
        alt="Book your luxury Menorca padel retreat with CourtSide — limited places 2026"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        width="1200"
        height="700"
      />
      <div class="absolute inset-0 bg-brand-dark/75 bg-gradient-to-t from-brand-dark via-brand-dark/60 to-brand-dark/40"></div>

      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Limited places each season</p>
        <h2 class="text-5xl md:text-7xl font-light text-brand-light mb-6 tracking-wide">Book Now</h2>
        <p class="text-brand-light/70 text-xl mb-12 max-w-lg mx-auto">
          Secure your place at the most exclusive padel retreat in the Mediterranean.
        </p>

        <!-- Quick booking summary -->
        <div class="flex flex-col md:flex-row justify-center gap-0 mb-10 border border-white/20 max-w-2xl mx-auto">
          <div class="flex-1 px-6 py-5 border-b md:border-b-0 md:border-r border-white/20 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Destination</p>
            <p class="text-brand-light font-semibold text-lg">Menorca</p>
          </div>
          <div class="flex-1 px-6 py-5 border-b md:border-b-0 md:border-r border-white/20 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Available Dates</p>
            <p class="text-brand-light font-semibold text-lg">30 Sep – 4 Oct 2026</p>
          </div>
          <div class="flex-1 px-6 py-5 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Accommodation</p>
            <p class="text-brand-light font-semibold text-lg">Suite · Villa · Executive</p>
          </div>
        </div>

        <a
          href="#"
          onclick="document.querySelector('[data-book-btn]')?.click(); return false;"
          class="inline-flex items-center gap-3 px-12 py-5 bg-brand-gold text-brand-dark font-bold uppercase tracking-widest text-sm hover:bg-brand-light transition-colors duration-300"
          aria-label="Secure your place at CourtSide Menorca padel retreat 2026"
        >
          Secure Your Place →
        </a>

        <p class="text-brand-light/30 text-sm mt-6">No commitment required. Speak with your Personal Concierge first.</p>
      </div>
    </section>

    <FooterIsland client:load />
  </main>
</Layout>
