---
import Layout from '../layouts/Layout.astro';
import RetreatLandingHero from '../components/RetreatLandingHero';
import RoomsSelector from '../components/RoomsSelector';
import MenorcaItinerary from '../components/MenorcaItinerary';
import FooterIsland from '../components/FooterIsland';

const seoTitle = "Menorca Padel Retreat 2026 | Luxury Padel Holiday Mediterranean | CourtSide";
const seoDescription = "Experience the ultimate luxury padel retreat in Menorca. Private coaching, yacht excursions, gourmet dining & exclusive villas. Limited places — October 2026.";
const seoKeywords = "Menorca padel retreat, luxury padel holiday Menorca, padel training Mediterranean, private padel villa Spain, CourtSide Menorca, padel vacation 2026, padel coaching retreat";

const menorcaSchema = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  "name": "CourtSide Menorca Padel Retreat 2026",
  "description": seoDescription,
  "touristType": ["Sports Enthusiast", "Luxury Traveler"],
  "itinerary": {
    "@type": "ItemList",
    "numberOfItems": 4,
    "name": "4-Day Menorca Padel Retreat Itinerary"
  },
  "provider": {
    "@type": "Organization",
    "name": "CourtSide Padel Retreats",
    "url": "https://courtsidepadel.com"
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "Personal Suite",
      "price": "120",
      "priceCurrency": "GBP",
      "availability": "https://schema.org/LimitedAvailability",
      "validFrom": "2026-10-08",
      "validThrough": "2026-10-11"
    },
    {
      "@type": "Offer",
      "name": "Full Villa",
      "price": "200",
      "priceCurrency": "GBP",
      "availability": "https://schema.org/LimitedAvailability"
    }
  ],
  "location": {
    "@type": "Place",
    "name": "Menorca, Balearic Islands",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Menorca",
      "addressCountry": "ES"
    }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What skill level is required for the Menorca padel retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our coaches tailor sessions to all levels, from beginners looking for foundation building to advanced players refining strategy."
      }
    },
    {
      "@type": "Question",
      "name": "Is the flight included in the Menorca padel retreat package?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Flights are not included in the standard package, however our private Concierge can arrange private charters or commercial flights upon request."
      }
    },
    {
      "@type": "Question",
      "name": "Are dietary requirements catered for at the retreat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our on-site private chef curates bespoke menus based on a detailed wellness questionnaire sent prior to your arrival."
      }
    }
  ]
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogImage="/imagenes/EM-2.jpg"
  canonical="https://courtsidepadel.com/menorca"
  schema={menorcaSchema}
>
  <!-- Second schema block for FAQ -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

  <main class="w-full min-h-screen bg-brand-dark flex flex-col relative overflow-x-hidden pt-24">

    <!-- ========== HERO ========== -->
    <RetreatLandingHero destination="menorca" bgVideoSrc="/vid2.mp4" client:load />

    <!-- ========== WHAT'S INCLUDED ========== -->
    <section id="includes" aria-label="What is included in the Menorca padel retreat" class="bg-brand-dark py-24 md:py-32 px-6 md:px-16">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-light text-center text-brand-light mb-4 tracking-wide">
          What's included?
        </h2>
        <p class="text-brand-light/50 text-center text-lg mb-20 max-w-xl mx-auto">
          Every detail curated so you can focus on performance and recovery.
        </p>

        <div class="flex flex-col gap-20">
          <!-- Feature 1: Chef -->
          <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
            <div class="w-full md:w-1/2 order-2 md:order-1">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Private Chef</p>
              <h3 class="text-2xl md:text-3xl font-light text-brand-light mb-5 leading-snug">
                Bespoke menus crafted around your wellness.
              </h3>
              <p class="text-brand-light/60 text-lg leading-relaxed">
                Our on-site private chef curates bespoke menus based on a detailed wellness questionnaire sent prior to your arrival. Every meal is a performance fuel.
              </p>
            </div>
            <div class="w-full md:w-1/2 order-1 md:order-2 overflow-hidden">
              <img
                src="/imagenes/bambu.jpg"
                alt="Private chef preparing bespoke wellness meals at CourtSide Menorca retreat"
                class="w-full h-72 md:h-96 object-cover"
                loading="lazy"
                width="800"
                height="600"
              />
            </div>
          </div>

          <!-- Feature 2: Padel Coaching -->
          <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
            <div class="w-full md:w-1/2 overflow-hidden">
              <img
                src="/imagenes/JOPS-1071.JPG"
                alt="Professional padel coaching session at CourtSide Menorca luxury retreat"
                class="w-full h-72 md:h-96 object-cover"
                loading="lazy"
                width="800"
                height="600"
              />
            </div>
            <div class="w-full md:w-1/2">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Expert Coaching</p>
              <h3 class="text-2xl md:text-3xl font-light text-brand-light mb-5 leading-snug">
                Sessions tailored to your exact level.
              </h3>
              <p class="text-brand-light/60 text-lg leading-relaxed">
                Our coaches tailor sessions to all levels, from beginners looking for foundation building to advanced players refining strategy on the court.
              </p>
            </div>
          </div>

          <!-- Feature 3: Yacht -->
          <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
            <div class="w-full md:w-1/2 order-2 md:order-1">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Yacht Escapes</p>
              <h3 class="text-2xl md:text-3xl font-light text-brand-light mb-5 leading-snug">
                Private sailing to secluded Mediterranean coves.
              </h3>
              <p class="text-brand-light/60 text-lg leading-relaxed">
                Afternoon charter yacht excursions to Menorca's most untouched coastlines. Premium catering, ocean relaxation, and on-deck physiotherapy as the sun sets.
              </p>
            </div>
            <div class="w-full md:w-1/2 order-1 md:order-2 overflow-hidden">
              <img
                src="/imagenes/Cala en porter.jpg"
                alt="Charter yacht excursion to secluded coves in Menorca, included in CourtSide retreat"
                class="w-full h-72 md:h-96 object-cover"
                loading="lazy"
                width="800"
                height="600"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== DISCOVER OUR ROOMS ========== -->
    <RoomsSelector client:load />

    <!-- ========== THE ITINERARY ========== -->
    <MenorcaItinerary client:load />

    <!-- ========== LICENCE TO LIVE ========== -->
    <section id="events" aria-label="Seasonal padel retreat events in Menorca" class="bg-white py-24 md:py-32 px-6 md:px-16">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-light text-center text-brand-dark mb-4 tracking-wide">
          Licence to live
        </h2>
        <p class="text-brand-dark/50 text-center text-lg mb-16 max-w-xl mx-auto">
          Choose your season. Each retreat offers a unique Menorca experience.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Event 1 -->
          <article class="relative overflow-hidden group cursor-pointer h-80">
            <img
              src="/imagenes/cap roig.jpg"
              alt="Summer Bank padel retreat Menorca — CourtSide luxury summer 2026"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              width="600"
              height="400"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-2 font-semibold">August 2026</p>
              <h3 class="text-2xl font-bold text-white uppercase tracking-wide">Summer Bank</h3>
              <p class="text-white/60 text-sm mt-1">Peak Mediterranean season</p>
            </div>
          </article>

          <!-- Event 2 -->
          <article class="relative overflow-hidden group cursor-pointer h-80">
            <img
              src="/imagenes/sa punta.jpg"
              alt="Christmas Holiday padel retreat Menorca — CourtSide luxury winter escape 2026"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              width="600"
              height="400"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-2 font-semibold">December 2026</p>
              <h3 class="text-2xl font-bold text-white uppercase tracking-wide">Christmas Holiday</h3>
              <p class="text-white/60 text-sm mt-1">A winter luxury escape</p>
            </div>
          </article>

          <!-- Event 3 -->
          <article class="relative overflow-hidden group cursor-pointer h-80">
            <img
              src="/imagenes/binifadet.jpeg"
              alt="October padel retreat Menorca — CourtSide autumn 2026 exclusive dates"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              width="600"
              height="400"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-2 font-semibold">October 2026</p>
              <h3 class="text-2xl font-bold text-white uppercase tracking-wide">Autumn Retreat</h3>
              <p class="text-white/60 text-sm mt-1">Ideal climate, fewer crowds</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ========== TESTIMONIALS ========== -->
    <section id="testimonials" aria-label="Guest reviews of CourtSide Menorca padel retreat" class="bg-brand-dark py-24 md:py-32 px-6 md:px-16">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-light text-center text-brand-light mb-4 tracking-wide">
          Trust that is shared
        </h2>
        <p class="text-brand-light/50 text-center text-lg mb-20 max-w-xl mx-auto">
          Guests who arrived as players. Left as loyalists.
        </p>

        <div class="flex flex-col md:flex-row gap-10 items-center">
          <!-- Testimonial image -->
          <div class="w-full md:w-1/2 overflow-hidden">
            <img
              src="/imagenes/IMG_2167.jpeg"
              alt="CourtSide Menorca retreat — luxury padel holiday Mediterranean setting"
              class="w-full h-80 md:h-[500px] object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>

          <!-- Testimonials -->
          <div class="w-full md:w-1/2 flex flex-col gap-10">
            <blockquote class="relative border-l-2 border-brand-gold pl-8">
              <p class="text-brand-light/80 text-lg md:text-xl font-light leading-relaxed italic">
                "Truly life-changing. The coaching sessions elevated my game, but the yacht day and gourmet dinners made it a complete luxury escape. Already booked for next year."
              </p>
              <footer class="mt-6 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full overflow-hidden bg-brand-gold/20 flex items-center justify-center">
                  <span class="text-brand-gold font-bold text-lg">T</span>
                </div>
                <div>
                  <cite class="text-brand-light font-semibold not-italic">Tomasz Campbell</cite>
                  <p class="text-brand-light/40 text-sm">Senior Director, London</p>
                  <div class="flex gap-1 mt-1" aria-label="5 out of 5 stars">
                    {"★★★★★".split("").map(s => <span class="text-brand-gold text-sm">{s}</span>)}
                  </div>
                </div>
              </footer>
            </blockquote>

            <blockquote class="relative border-l-2 border-brand-gold/40 pl-8">
              <p class="text-brand-light/60 text-lg font-light leading-relaxed italic">
                "The attention to detail is unreal. From the airport transfer to the farewell dinner, every moment felt tailored. This is how a padel retreat should be."
              </p>
              <footer class="mt-6 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full overflow-hidden bg-brand-gold/20 flex items-center justify-center">
                  <span class="text-brand-gold font-bold text-lg">A</span>
                </div>
                <div>
                  <cite class="text-brand-light/70 font-semibold not-italic">Ana Martínez</cite>
                  <p class="text-brand-light/40 text-sm">CEO, Madrid</p>
                  <div class="flex gap-1 mt-1" aria-label="5 out of 5 stars">
                    {"★★★★★".split("").map(s => <span class="text-brand-gold/60 text-sm">{s}</span>)}
                  </div>
                </div>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FAQ ========== -->
    <section id="faq" aria-label="Frequently asked questions about Menorca padel retreat" class="bg-brand-dark-2 py-24 md:py-32 px-6 md:px-16">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-light text-center text-brand-light mb-16 tracking-wide">
          Frequently Asked Questions
        </h2>

        <dl class="space-y-0 divide-y divide-white/10">
          <div class="py-8">
            <dt class="text-xl font-light text-brand-light mb-3">What skill level is required?</dt>
            <dd class="text-brand-light/60 leading-relaxed">Our coaches tailor sessions to all levels, from beginners looking for foundation building to advanced players refining strategy.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-brand-light mb-3">Is the flight included?</dt>
            <dd class="text-brand-light/60 leading-relaxed">Flights are not included in the standard package, however our private Concierge can arrange private charters or commercial flights upon request.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-brand-light mb-3">What about dietary requirements?</dt>
            <dd class="text-brand-light/60 leading-relaxed">Our on-site private chef curates bespoke menus based on a detailed wellness questionnaire sent prior to your arrival.</dd>
          </div>
          <div class="py-8">
            <dt class="text-xl font-light text-brand-light mb-3">How many guests per retreat?</dt>
            <dd class="text-brand-light/60 leading-relaxed">We cap each retreat to ensure exclusivity. Personal suites accommodate individuals and couples; Full Villa exclusivity is available for groups of 8–20 guests.</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ========== BOOK NOW CTA ========== -->
    <section id="book" aria-label="Book your CourtSide Menorca padel retreat" class="relative py-28 md:py-40 px-6 md:px-16 overflow-hidden">
      <img
        src="/imagenes/IMG_2914.JPG"
        alt="Book your luxury Menorca padel retreat with CourtSide — limited places 2026"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        width="1400"
        height="800"
      />
      <div class="absolute inset-0 bg-brand-dark/75 bg-gradient-to-t from-brand-dark via-brand-dark/60 to-brand-dark/40"></div>

      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="text-xs uppercase tracking-widest text-brand-gold mb-4 font-semibold">Limited places each season</p>
        <h2 class="text-5xl md:text-7xl font-light text-brand-light mb-6 tracking-wide">Book Now</h2>
        <p class="text-brand-light/70 text-xl mb-12 max-w-lg mx-auto">
          Secure your place at the most exclusive padel retreat in the Mediterranean.
        </p>

        <!-- Quick booking summary -->
        <div class="flex flex-col md:flex-row justify-center gap-0 mb-10 border border-white/20 max-w-2xl mx-auto">
          <div class="flex-1 px-6 py-5 border-b md:border-b-0 md:border-r border-white/20 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Destination</p>
            <p class="text-brand-light font-semibold text-lg">Menorca</p>
          </div>
          <div class="flex-1 px-6 py-5 border-b md:border-b-0 md:border-r border-white/20 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Available Dates</p>
            <p class="text-brand-light font-semibold text-lg">Oct 8–11 · Oct 21–25</p>
          </div>
          <div class="flex-1 px-6 py-5 text-left">
            <p class="text-xs uppercase tracking-widest text-brand-light/40 mb-1">Accommodation</p>
            <p class="text-brand-light font-semibold text-lg">Suite · Villa · Executive</p>
          </div>
        </div>

        <a
          href="#"
          onclick="document.querySelector('[data-book-btn]')?.click(); return false;"
          class="inline-flex items-center gap-3 px-12 py-5 bg-brand-gold text-brand-dark font-bold uppercase tracking-widest text-sm hover:bg-brand-light transition-colors duration-300"
          aria-label="Secure your place at CourtSide Menorca padel retreat 2026"
        >
          Secure Your Place →
        </a>

        <p class="text-brand-light/30 text-sm mt-6">No commitment required. Speak with your Personal Concierge first.</p>
      </div>
    </section>

    <FooterIsland client:load />
  </main>
</Layout>
